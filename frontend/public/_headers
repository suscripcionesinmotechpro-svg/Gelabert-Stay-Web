## Netlify HTTP Headers
## These headers improve Security, Performance, and SEO signals

# --- Hashed Assets: Aggressive long-term caching (Vite generates unique names) ---
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# --- Static Public Assets: Check for updates (no hashes) ---
/*.png
  Cache-Control: public, max-age=0, must-revalidate
/*.jpg
  Cache-Control: public, max-age=0, must-revalidate
/*.jpeg
  Cache-Control: public, max-age=0, must-revalidate
/*.webp
  Cache-Control: public, max-age=0, must-revalidate
/*.svg
  Cache-Control: public, max-age=0, must-revalidate
/*.ico
  Cache-Control: public, max-age=0, must-revalidate
/*.woff
  Cache-Control: public, max-age=31536000, immutable
/*.woff2
  Cache-Control: public, max-age=31536000, immutable
/*.ttf
  Cache-Control: public, max-age=31536000, immutable

# --- Sitemap/Robots: Short cache ---
/sitemap.xml
  Cache-Control: public, max-age=0, must-revalidate
  Content-Type: application/xml; charset=utf-8
/robots.txt
  Cache-Control: public, max-age=0, must-revalidate

# --- HTML & SPA Fallback: NEVER CACHE ---
/*
  Cache-Control: no-cache, no-store, must-revalidate
  # Security headers
  X-Frame-Options: SAMEORIGIN
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=(self)
  Strict-Transport-Security: max-age=63072000; includeSubDomains; preload

